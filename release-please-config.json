{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "_comment_versioning": "Pre-1.0 bump policy: feat: and fix: both bump patch (0.1.0 → 0.1.1); only BREAKING CHANGE / feat! bumps minor (0.1.0 → 0.2.0). Keeps release friction low while the API is still moving. Both flags are pre-1.0-only — release-please switches to standard semver automatically once appVersion crosses 1.0.0.",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    ".": {
      "package-name": "paddock",
      "extra-files": [
        {
          "type": "generic",
          "path": "charts/paddock/Chart.yaml"
        }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "Features", "hidden": false },
        { "type": "fix", "section": "Bug Fixes", "hidden": false },
        { "type": "perf", "section": "Performance", "hidden": false },
        { "type": "revert", "section": "Reverts", "hidden": false },
        { "type": "docs", "section": "Documentation", "hidden": false },
        { "type": "refactor", "section": "Code Refactoring", "hidden": false },
        { "type": "chore", "section": "Chores", "hidden": true },
        { "type": "test", "section": "Tests", "hidden": true },
        { "type": "build", "section": "Build", "hidden": true },
        { "type": "ci", "section": "CI", "hidden": true }
      ]
    }
  }
}
