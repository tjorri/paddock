---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <p>
      Paddock is open source under the
      <a href="https://github.com/tjorri/paddock/blob/main/LICENSE">Apache 2.0 License</a>.
      Site content is
      <a href="https://creativecommons.org/licenses/by/4.0/" rel="license noopener">CC BY 4.0</a>.
    </p>
    <p class="site-footer__meta">
      © {year} Paddock contributors ·
      <a href="https://github.com/tjorri/paddock">GitHub</a> ·
      <a href={`${base}/docs/`}>Docs</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    background: var(--color-bg-2);
    padding-block: var(--space-6);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .site-footer__inner > p { max-width: none; }
  .site-footer__meta { margin-top: var(--space-2); }
</style>
