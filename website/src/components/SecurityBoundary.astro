---
---
<svg class="sec" viewBox="0 0 960 320" role="img" aria-labelledby="sec-title">
  <title id="sec-title">Paddock security boundary</title>

  <!-- Operator side: broker, secrets -->
  <g class="g-operator">
    <rect x="20" y="40" width="280" height="240" rx="8" />
    <text x="160" y="72" text-anchor="middle" class="t-heading">Operator side</text>
    <text x="160" y="110" text-anchor="middle">Broker</text>
    <text x="160" y="140" text-anchor="middle" class="t-muted">- AnthropicAPI</text>
    <text x="160" y="160" text-anchor="middle" class="t-muted">- GitHubApp</text>
    <text x="160" y="180" text-anchor="middle" class="t-muted">- PATPool</text>
    <text x="160" y="200" text-anchor="middle" class="t-muted">- Static</text>
    <text x="160" y="240" text-anchor="middle">Long-lived secrets</text>
  </g>

  <!-- The line -->
  <line class="boundary" x1="480" y1="20" x2="480" y2="300" />
  <text x="480" y="18" text-anchor="middle" class="t-boundary">SECURITY BOUNDARY</text>

  <!-- Agent side: pod -->
  <g class="g-agent">
    <rect x="500" y="40" width="440" height="240" rx="8" />
    <text x="720" y="72" text-anchor="middle" class="t-heading">Agent side (Job pod)</text>

    <rect x="520" y="100" width="180" height="60" rx="6" class="r-proxy"/>
    <text x="610" y="125" text-anchor="middle" class="t-heading">Proxy sidecar</text>
    <text x="610" y="145" text-anchor="middle" class="t-muted">MITM TLS · ValidateEgress · SubstituteAuth</text>

    <rect x="740" y="100" width="180" height="60" rx="6" class="r-agent"/>
    <text x="830" y="125" text-anchor="middle" class="t-heading">Agent container</text>
    <text x="830" y="145" text-anchor="middle" class="t-muted">Paddock-issued bearer only</text>

    <text x="720" y="210" text-anchor="middle">Egress is forced through the proxy.</text>
    <text x="720" y="232" text-anchor="middle">Real provider keys never reach the agent.</text>
  </g>

  <!-- Arrows -->
  <line class="arrow" x1="300" y1="130" x2="500" y2="130" />
  <line class="arrow" x1="700" y1="130" x2="740" y2="130" />
</svg>

<style>
  .sec {
    width: 100%;
    height: auto;
    max-width: 60rem;
    display: block;
    margin: var(--space-5) auto;
  }
  .sec rect {
    fill: var(--color-bg-2);
    stroke: var(--color-rule);
    stroke-width: 1;
  }
  .sec text {
    fill: var(--color-text);
    font-family: var(--font-sans);
    font-size: 14px;
  }
  .sec .t-heading { font-weight: 600; fill: var(--color-accent); }
  .sec .t-muted   { fill: var(--color-text-muted); font-size: 12px; }
  .sec .t-boundary {
    fill: var(--color-link);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
  }
  .sec .boundary {
    stroke: var(--color-link);
    stroke-width: 2;
    stroke-dasharray: 6 4;
  }
  .sec .arrow {
    stroke: var(--color-text-muted);
    stroke-width: 1.5;
  }
  .sec .r-proxy { stroke: var(--color-accent); stroke-width: 1.5; }
  .sec .r-agent { stroke: var(--color-rule); }
</style>
